// Signals For Me — data model
// Postgres (works locally and on serverless hosts like Vercel). The `embedding`
// field is stored as a JSON string for now; upgrade to pgvector later for
// native semantic search.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A user of the platform (business or consumer).
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  // set by Auth.js when a magic-link email is verified
  emailVerified DateTime?
  image         String?
  // "consumer" | "business"
  audience      String         @default("business")
  // Opportunity Engine business profile (optional). businessType is a key from
  // BUSINESS_TYPES (e.g. "dentist"); growthGoal is a GrowthGoal (e.g. "leads").
  businessType  String?
  location      String?
  growthGoal    String?
  // "free" | "pro" | "team"
  plan          String         @default("free")
  // when true, the user has unsubscribed from the email digest
  digestOptOut  Boolean        @default(false)
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  events        SignalEvent[]
  accounts      Account[]
  sessions      Session[]
}

// ---- Auth.js (NextAuth) adapter models ----
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// A user's saved interest: which signal types/categories they want, with thresholds.
// This is the personalization layer ("Signals For Nelson").
model Subscription {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "business" | "consumer" | null (any)
  category      String?
  // a signal type key from the taxonomy (e.g. "funding"), or null for all
  signalType    String?
  // optional free-text keyword the signal must match
  keyword       String?
  // only surface signals at/above this confidence (0-1)
  minConfidence Float   @default(0.5)
  createdAt     DateTime @default(now())

  @@index([userId])
}

// The unified Signal object — the heart of the product. A signal is the
// "Opportunity Engine" output: what changed, who it affects, the concrete
// opportunities it creates (1..many), and the risks it opens.
model Signal {
  id              String   @id @default(cuid())
  // taxonomy type key, e.g. "funding", "hiring", "buying_intent", "travel_deal"
  type            String
  // "business" | "consumer" — primary audience of the signal as a whole
  category        String
  // taxonomy group, e.g. "Funding Signals"
  groupName       String
  title           String
  summary         String
  // one-line "what changed" distinct from the longer summary
  whatChanged     String?
  entityName      String?
  entityDomain    String?
  entityLocation  String?
  // JSON-encoded string[]; reasons it matters (legacy/general bullets)
  whyItMatters    String
  // JSON-encoded string[]; who gains from this change
  whoBenefits     String   @default("[]")
  // JSON-encoded string[]; who is threatened by this change
  whoAtRisk       String   @default("[]")
  // JSON-encoded string[]; industries affected
  affectedIndustries String @default("[]")
  confidence      Float
  suggestedAction String?
  sourceUrl       String?
  // origin feed type: "news" | "job_board" | "gov" | "social" | "mock"
  rawSource       String
  // JSON-encoded number[] embedding (pgvector column in prod)
  embedding       String?
  // normalized fingerprint for deduplication
  dedupKey        String   @unique
  detectedAt      DateTime @default(now())
  events          SignalEvent[]
  opportunities   Opportunity[]
  risks           Risk[]

  @@index([type])
  @@index([category])
  @@index([detectedAt])
}

// A concrete opportunity created by a signal. One signal yields many — mixed
// across business and consumer audiences (e.g. "AI Chip Consulting" for
// business, "AI Hardware Training" for consumers).
model Opportunity {
  id         String @id @default(cuid())
  signalId   String
  signal     Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  title      String
  // "business" | "consumer"
  audience   String
  confidence Float

  @@index([signalId])
  @@index([audience])
}

// A risk created/exposed by a signal (who now has a problem).
model Risk {
  id         String @id @default(cuid())
  signalId   String
  signal     Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  title      String
  confidence Float

  @@index([signalId])
}

// Engagement / feedback used later to calibrate confidence + personalization.
model SignalEvent {
  id        String   @id @default(cuid())
  signalId  String
  signal    Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // "view" | "save" | "dismiss" | "action_taken"
  kind      String
  createdAt DateTime @default(now())

  @@index([signalId])
}

// Bookkeeping for pipeline runs (observability).
model PipelineRun {
  id           String   @id @default(cuid())
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  itemsFetched Int      @default(0)
  signalsKept  Int      @default(0)
  duplicates   Int      @default(0)
  rejected     Int      @default(0)
  provider     String   @default("mock")
  note         String?
}
