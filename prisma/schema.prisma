// Signals For Me — data model
// Dev: SQLite (zero-setup). Prod: switch `provider` to "postgresql" and add pgvector
// for the `embedding` field (store as vector instead of JSON string).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A user of the platform (business or consumer).
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  // "consumer" | "business"
  audience      String         @default("business")
  // "free" | "pro" | "team"
  plan          String         @default("free")
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  events        SignalEvent[]
}

// A user's saved interest: which signal types/categories they want, with thresholds.
// This is the personalization layer ("Signals For Nelson").
model Subscription {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "business" | "consumer" | null (any)
  category      String?
  // a signal type key from the taxonomy (e.g. "funding"), or null for all
  signalType    String?
  // optional free-text keyword the signal must match
  keyword       String?
  // only surface signals at/above this confidence (0-1)
  minConfidence Float   @default(0.5)
  createdAt     DateTime @default(now())

  @@index([userId])
}

// The unified Signal object — the heart of the product.
model Signal {
  id              String   @id @default(cuid())
  // taxonomy type key, e.g. "funding", "hiring", "buying_intent", "travel_deal"
  type            String
  // "business" | "consumer"
  category        String
  // taxonomy group, e.g. "Funding Signals"
  groupName       String
  title           String
  summary         String
  entityName      String?
  entityDomain    String?
  entityLocation  String?
  // JSON-encoded string[]; reasons it matters
  whyItMatters    String
  confidence      Float
  suggestedAction String?
  sourceUrl       String?
  // origin feed type: "news" | "job_board" | "gov" | "social" | "mock"
  rawSource       String
  // JSON-encoded number[] embedding (pgvector column in prod)
  embedding       String?
  // normalized fingerprint for deduplication
  dedupKey        String   @unique
  detectedAt      DateTime @default(now())
  events          SignalEvent[]

  @@index([type])
  @@index([category])
  @@index([detectedAt])
}

// Engagement / feedback used later to calibrate confidence + personalization.
model SignalEvent {
  id        String   @id @default(cuid())
  signalId  String
  signal    Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // "view" | "save" | "dismiss" | "action_taken"
  kind      String
  createdAt DateTime @default(now())

  @@index([signalId])
}

// Bookkeeping for pipeline runs (observability).
model PipelineRun {
  id           String   @id @default(cuid())
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  itemsFetched Int      @default(0)
  signalsKept  Int      @default(0)
  duplicates   Int      @default(0)
  rejected     Int      @default(0)
  provider     String   @default("mock")
  note         String?
}
