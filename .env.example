# ---- Database (Postgres) ----
# Use one hosted Postgres connection string locally AND on Vercel.
# Free options: Neon (neon.tech), Supabase, or Vercel Postgres.
# Neon example (note the required sslmode):
DATABASE_URL="postgresql://user:password@ep-xxxx.eu-west-2.aws.neon.tech/signalsforme?sslmode=require"

# ---- Security ----
# Secret required to trigger privileged ingestion (custom feed URLs / scheduled
# runs). Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""
# Optional comma-separated hostname allowlist for server-side feed fetches (SSRF
# guard). Leave blank to allow any PUBLIC host (private/internal IPs are always
# blocked). Example: "feeds.bbci.co.uk,www.gov.uk"
FEED_URL_ALLOWLIST=""

# ---- AI provider ----
# Leave blank to use the built-in deterministic MOCK provider (no cost, runs offline).
# Set a key to switch to real LLM extraction.
AI_PROVIDER="mock"            # "mock" | "openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ---- Auth (Auth.js / NextAuth v5) ----
# Required. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""
# Public base URL of the deployment (used for magic-link callbacks, OG tags, sitemap).
# On Vercel this is inferred automatically; set it for a custom domain.
NEXT_PUBLIC_SITE_URL="https://signals-for-me.vercel.app"

# ---- Email (magic-link sign-in + digest) ----
# Leave RESEND_API_KEY blank in dev: emails (incl. sign-in links) are printed to
# the server console instead of being sent. Set it in production to send for real.
RESEND_API_KEY=""
DIGEST_FROM="Signals For Me <onboarding@resend.dev>"
# Optional. Where replies go (defaults to the DIGEST_FROM address).
REPLY_TO=""

# ---- Billing (production) ----
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PRICE_PRO=""
# NEXT_PUBLIC_STRIPE_PRICE_TEAM=""
