# ---- Database ----
# Dev uses SQLite out of the box. For production switch to Postgres + pgvector:
# DATABASE_URL="postgresql://user:pass@host:5432/signalsforme?schema=public"
DATABASE_URL="file:./dev.db"

# ---- AI provider ----
# Leave blank to use the built-in deterministic MOCK provider (no cost, runs offline).
# Set a key to switch to real LLM extraction.
AI_PROVIDER="mock"            # "mock" | "openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ---- Email digest (production) ----
# RESEND_API_KEY=""
# DIGEST_FROM="signals@yourdomain.com"

# ---- Billing (production) ----
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PRICE_PRO=""
# NEXT_PUBLIC_STRIPE_PRICE_TEAM=""
